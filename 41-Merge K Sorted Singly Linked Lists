/**
 * Definition for singly linked list.
 * public class ListNode {
 * int val;
 * ListNode next;
 * ListNode() {}
 * ListNode(int val) { this.val = val; }
 * ListNode(int val, ListNode next) { this.val = val; this.next = next; }
 * }
 */


//Bruteforce approach

class Solution {
    public ListNode mergeKLists(ListNode[] lists) {
        // Edge case: no lists provided
        if (lists.length == 0) {
            return null;
        }

        // Start recursive merging from index 0
        return mergeKLists(lists, 0);
    }

    private ListNode mergeKLists(ListNode[] lists, int index) {
        // Base case: last list, nothing left to merge
        if (index == lists.length - 1) {
            return lists[index];
        }

        // Recursively merge all lists on the right side `rightHead` represents the merged head of lists[index+1 ... end]
        ListNode rightHead = mergeKLists(lists, index + 1);
        ListNode rightHead = mergeKLists(lists, index + 1);

        // Then merge current list with the result
        return merge(lists[index], rightHead);
    }

    private ListNode merge(ListNode head1, ListNode head2) {
        ListNode node1 = head1;
        ListNode node2 = head2;

        ListNode mergedHead = new ListNode(-1);
        ListNode mergedTail = mergedHead;

        // Merge nodes while both lists have elements
        while (node1 != null && node2 != null) {
            if (node1.val <= node2.val) {
                ListNode next = node1.next;
                node1.next = null;
                mergedTail.next = node1;
                node1 = next;
            } else {
                ListNode next = node2.next;
                node2.next = null;
                mergedTail.next = node2;
                node2 = next;
            }

            // Advance merged list tail
            mergedTail = mergedTail.next;
        }

        // Attach remaining nodes from list1 if any
        if (node1 != null) {
            mergedTail.next = node1;
        }

        // Attach remaining nodes from list2 if any
        if (node2 != null) {
            mergedTail.next = node2;
        }

        return mergedHead.next;
    }
}


//Optimal appraoch 

class Solution {
    /**
    * Why Divide & Conquer is better than the previous recursive approach
    * -------------------------------------------------------------------
    *
    * The earlier recursive solution merged lists in a chain-like manner:
    *
    * merge(L1, merge(L2, merge(L3, merge(L4, L5))))
    *
    * Which unfolds like:
    *
    * merge(L4, L5)
    * merge(L3, (L4 + L5))
    * merge(L2, (L3 + L4 + L5))
    * merge(L1, (L2 + L3 + L4 + L5))
    *
    * Notice what happens here:
    * -------------------------
    * The merged list keeps growing at every step.
    *
    * As the intermediate result becomes larger, earlier nodes are repeatedly
    * scanned in every subsequent merge.
    *
    * Example (assuming each list has N nodes):
    *
    * merge(L4, L5)        → process 2N nodes
    * merge(L3, result)    → process 3N nodes
    * merge(L2, result)    → process 4N nodes
    * merge(L1, result)    → process 5N nodes
    *
    * So nodes from earlier lists get processed multiple times.
    *
    * Total work becomes roughly:
    *
    * N + 2N + 3N + ... + KN  ≈  O(KN)
    *
    *
    * How Divide & Conquer improves this
    * ----------------------------------
    *
    * Instead of merging lists sequentially, we split the array of lists
    * into two halves and merge them recursively.
    *
    * Example:
    *
    * lists = [L1, L2, L3, L4]
    *
    * Step 1:
    * merge(L1, L2)    merge(L3, L4)
    *
    * Step 2:
    * merge((L1+L2), (L3+L4))
    *
    * This creates a balanced merge tree (similar to Merge Sort).
    *
    * Key observation:
    * ----------------
    * At each level of the merge tree, every node across all lists
    * is processed exactly once.
    *
    * The height of this merge tree is:
    *
    * log(K)
    *
    * Therefore each node participates in at most log(K) merge operations.
    *
    *
    * Final Complexity
    * ----------------
    *
    * Let N = total number of nodes across all lists.
    *
    * Work per level  → O(N)
    * Number of levels → O(log K)
    *
    * Total Time Complexity:
    * O(N log K)
    *
    * Space Complexity:
    * O(log K) recursion stack
    */
    public ListNode mergeKLists(ListNode[] lists) {
        if (lists.length == 0) {
            return null;
        }

        return mergeKLists(lists, 0, lists.length - 1);
    }

    private ListNode mergeKLists(ListNode[] lists, int low, int high) {
        // Base case: only one list
        if (low == high) {
            return lists[low];
        }

        // Split the list range into two halves to keep merges balanced
        int mid = low + (high - low) / 2;

        // Recursively merge left half
        ListNode leftHead = mergeKLists(lists, low, mid);

        // Recursively merge right half
        ListNode rightHead = mergeKLists(lists, mid + 1, high);

        // Merge the two sorted halves
        return merge(leftHead, rightHead);
    }

    private ListNode merge(ListNode head1, ListNode head2) {
        ListNode node1 = head1;
        ListNode node2 = head2;

        ListNode mergedHead = new ListNode(-1);
        ListNode mergedTail = mergedHead;

        while (node1 != null && node2 != null) {
            if (node1.val <= node2.val) {
                ListNode next = node1.next;
                node1.next = null;
                mergedTail.next = node1;
                node1 = next;
            } else {
                ListNode next = node2.next;
                node2.next = null;
                mergedTail.next = node2;
                node2 = next;
            }

            mergedTail = mergedTail.next;
        }

        if (node1 != null) {
            mergedTail.next = node1;
        }

        if (node2 != null) {
            mergedTail.next = node2;
        }

        return mergedHead.next;
    }
}
