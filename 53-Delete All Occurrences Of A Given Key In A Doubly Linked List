class Solution {
    static Node deleteAllOccurOfX(Node head, int key) {
        // Start traversing from the head
        Node node = head;

        while (node != null) {
            // If current node contains the key, delete it
            if (node.data == key) {

                Node prevNode = node.prev;
                Node nextNode = node.next;

                /*
                 * If the node to be deleted is the head,
                 * update head to the next node.
                 */
                if (node == head) {
                    head = node.next;
                }

                /*
                 * Update forward link of the previous node
                 * so it skips the current node.
                 */
                if (prevNode != null) {
                    prevNode.next = nextNode;
                }

                /*
                 * Update backward link of the next node
                 * so it skips the current node.
                 */
                if (nextNode != null) {
                    nextNode.prev = prevNode;
                }

                /*
                 * Completely detach the current node
                 * from the list.
                 */
                node.next = null;
                node.prev = null;

                // Continue traversal from the next node
                node = nextNode;

            } else {
                // Move forward if current node is not deleted
                node = node.next;
            }
        }

        // Return possibly updated head
        return head;
    }
}
