class Solution {
    Node removeDuplicates(Node head) {
        // If the list has only one node, no duplicates can exist
        if (head.next == null) {
            return head;
        }

        // Start checking from the second node
        Node node = head.next;

        while (node != null) {
            Node prevNode = node.prev;
            Node nextNode = node.next;

            /*
             * If the current node has the same value as the previous node,
             * it means this node is a duplicate.
             */
            if (prevNode.data == node.data) {

                /*
                 * Remove the current node by linking the previous node
                 * directly to the next node.
                 */
                prevNode.next = nextNode;

                /*
                 * If the next node exists, update its prev pointer
                 * so that it now points back to prevNode.
                 */
                if (nextNode != null) {
                    nextNode.prev = prevNode;
                }

                /*
                 * Detach the current node completely from the list.
                 * This is optional but good practice.
                 */
                node.next = null;
                node.prev = null;
            }

            // Move to the next node in the list
            node = nextNode;
        }

        // Head remains unchanged because duplicates are removed only from nodes after the head.
        return head;
    }
}
