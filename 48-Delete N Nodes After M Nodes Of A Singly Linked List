class Solution {
    /**
     * Important Constraint:
     * ---------------------
     * The problem guarantees that M > 0.
     *
     * This means the first node (head) will always be part of the
     * kept segment, so the head of the list will never be deleted.
     * Therefore the head reference always remains unchanged.
     *
     */
    static void linkdelete(Node head, int n, int m) {
        Node node = head;

        // Stores the last node that we decided to keep
        Node lastKeptNode = null;

        while (node != null) {
            /**
             * Keep the next M nodes
             *
             * Move forward M nodes and keep track of the last node
             * that should remain in the list.
             */
            for (int count = 1; (count <= m && node != null); count++) {
                lastKeptNode = node;
                node = node.next;
            }

            // If we reach the end while keeping nodes, nothing more to delete
            if (node == null) {
                break;
            }

            /**
             * Delete the next N nodes
             *
             * We move forward N nodes while remembering the last node
             * that belongs to the deletion segment.
             */
            Node lastDeletedNode = null;

            for (int count = 1; (count <= n && node != null); count++) {
                lastDeletedNode = node;
                node = node.next;
            }

            // Disconnect the deleted segment from the list.
            lastDeletedNode.next = null;

            /**
             * Connect the last kept node to the next valid node
             * that appears after the deleted segment.
             */
            lastKeptNode.next = node;
        }
    }
}
