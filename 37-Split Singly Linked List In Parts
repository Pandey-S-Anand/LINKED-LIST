/**
 * Definition for singly-linked list.
 * public class ListNode {
 *     int val;
 *     ListNode next;
 *     ListNode() {}
 *     ListNode(int val) { this.val = val; }
 *     ListNode(int val, ListNode next) { this.val = val; this.next = next; }
 * }
 */

class Solution {
    /*
     * We must split the linked list into k consecutive parts such that:
     *
     * 1) All parts are as equal in size as possible.
     * 2) No two parts differ in size by more than 1 node.
     * 3) Earlier parts must be greater than or equal to later parts.
     * 4) Some parts may be null if k > length.
     *
     * Key Idea
     * --------
     * If total nodes = L and parts = k
     *
     * baseSize = L / k
     * extraNodes = L % k
     *
     * Every part gets at least baseSize nodes.
     * The first extraNodes parts receive one additional node.
     *
     * This guarantees:
     * - Size difference between parts ≤ 1
     * - Earlier parts are always larger or equal in size.
     */

    public ListNode[] splitListToParts(ListNode head, int k) {
        // Result array that will store the head of each part
        ListNode[] parts = new ListNode[k];

        // Index used to fill the parts array
        int partIndex = 0;

        // Compute total number of nodes in the list
        int length = getLength(head);

        // Minimum nodes each part must contain
        int minNodesPerPart = length / k;

        // Remaining nodes that must be distributed one per part
        int remainingExtraNodes = length % k;

        // Traversal pointer
        ListNode node = head;

        // Marks the starting node of the current part
        ListNode currentPartHead = head;

        /*
         * Determine how many nodes the first part should contain.
         *
         * Every part must contain at least minNodesPerPart nodes.
         *
         * If extra nodes exist, the first few parts receive one extra node.
         */
        int nodesRemainingInCurrentPart = minNodesPerPart;

        if (remainingExtraNodes != 0) {
            nodesRemainingInCurrentPart++; // allocate one extra node
            remainingExtraNodes--; // reduce remaining extra nodes
        }

        // Traverse the linked list and build each part
        while (node != null) {
            // One node of the current part has been consumed
            nodesRemainingInCurrentPart--;

            /*
             * When this becomes 0, the current part has reached
             * its required size and must be finalized.
             */
            if (nodesRemainingInCurrentPart == 0) {
                // Store the head of the current part
                parts[partIndex++] = currentPartHead;

                //Save the head of the next part before breaking the list.
                ListNode nextPartHead = node.next;

                //Break the current part from the rest of the list.
                node.next = null;

                //Move pointers to start constructing the next part.
                currentPartHead = nextPartHead;
                node = nextPartHead;

                /*
                 * Determine the required size for the next part.
                 * Again start with the base size.
                 */
                nodesRemainingInCurrentPart = minNodesPerPart;

                /*
                 * If extra nodes are still available,
                 * assign one extra node to this part.
                 */
                if (remainingExtraNodes != 0) {
                    nodesRemainingInCurrentPart++;
                    remainingExtraNodes--;
                }

            } else {
                /*
                 * Current part still needs more nodes,
                 * continue traversing the list.
                 */
                node = node.next;
            }
        }

        /*
         * If k > length, some entries in the parts array
         * will remain null, which is the expected behavior.
         */

        return parts;
    }

    private int getLength(ListNode head) {
        ListNode node = head;
        int length = 0;

        while (node != null) {
            node = node.next;
            length++;
        }

        return length;
    }
}
