class Solution {
    /**
     * Flattens a linked list where:
     * - 'next' pointers connect different vertical lists
     * - 'bottom' pointers form a sorted list vertically
     *
     * Example structure:
     *
     * 5 → 10 → 19 → 28
     * |    |     |     |
     * 7    20    22    35
     * |          |     |
     * 8          50    40
     * |                |
     * 30               45
     *
     * Each vertical list (via bottom) is already sorted.
     *
     * Strategy:
     * - Recursively flatten the list on the right.
     * - Then merge the current vertical list with the already flattened right side.
     */
    public Node flatten(Node root) {
        // If list is empty or only one vertical list exists, it is already flattened.
        if (root == null || root.next == null) {
            return root;
        }

        /**
         * Recursively flatten the lists to the right.
         *
         * After this call, 'rightHead' represents the flattened
         * version of all lists to the right of the current root.
         */
        Node rightHead = flatten(root.next);

        /**
         * Merge the current vertical list (root)
         * with the flattened right list.
         */
        return mergeSortedLists(root, rightHead);
    }

    /**
     * Merges two sorted linked lists that use the 'bottom' pointer.
     *
     * head1 → bottom chain
     * head2 → bottom chain
     *
     * Returns the head of the merged sorted bottom list.
     */
    private Node mergeSortedLists(Node head1, Node head2) {
        Node mergedHead = new Node(-1);
        Node mergedTail = mergedHead;

        Node node1 = head1;
        Node node2 = head2;

        while (node1 != null && node2 != null) {

            if (node1.data <= node2.data) {
                // Attach node1 and move node1 down
                mergedTail.bottom = node1;
                node1 = node1.bottom;

            } else {
                // Attach node2 and move node2 down
                mergedTail.bottom = node2;
                node2 = node2.bottom;
            }

            // Advance the tail of the merged list
            mergedTail = mergedTail.bottom;
        }

        /**
         * If one list still has remaining nodes,
         * attach the remaining portion directly
         * because it is already sorted.
         */
        if (node1 != null) {
            mergedTail.bottom = node1;
            mergedTail = mergedTail.bottom;
        }

        if (node2 != null) {
            mergedTail.bottom = node2;
            mergedTail = mergedTail.bottom;
        }

        // The merged list starts after the dummy node.
        return mergedHead.bottom;
    }
}
