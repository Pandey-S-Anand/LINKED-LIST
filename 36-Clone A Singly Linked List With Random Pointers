/*
// Definition for a Node.
class Node {
    int val;
    Node next;
    Node random;

    public Node(int val) {
        this.val = val;
        this.next = null;
        this.random = null;
    }
}
*/

//Bruteforce approach

class Solution {
    /**
     * Creates a deep copy of a linked list where each node contains:
     * - a 'next' pointer
     * - a 'random' pointer that may point to any node in the list (or null)
     *
     * Approach (HashMap / Two-Pass Method):
     *
     * Pass 1:
     * - Traverse the original list.
     * - For every original node, create a new copy node with the same value.
     * - Store the mapping:
     *        originalNode → copiedNode
     *
     * Pass 2:
     * - Traverse the original list again.
     * - Use the stored mapping to correctly assign:
     *        copiedNode.next
     *        copiedNode.random
     *
     * Why this works:
     * The HashMap allows us to instantly locate the copied version
     * of any original node when assigning pointers.
     */
    public Node copyRandomList(Node head) {
        // Map storing relation between original nodes and their copies
        Map<Node, Node> nodeCopyMap = new HashMap<>();

        Node node = head;

        // Create copy nodes and store mapping.
        while (node != null) {
            Node copiedNode = new Node(node.val);
            // Map original node to its copy
            nodeCopyMap.put(node, copiedNode);
            node = node.next;
        }

        node = head;

        //Assign next and random pointers for copied nodes.
        while (node != null) {
            Node copiedNode = nodeCopyMap.get(node);
            // Set next pointer using the mapping
            copiedNode.next = nodeCopyMap.get(node.next);
            // Set random pointer using the mapping
            copiedNode.random = nodeCopyMap.get(node.random);
            node = node.next;
        }

        // The head of the deep-copied list is the mapped copy of the original head.
        return nodeCopyMap.get(head);
    }
}


//Optimal Approach

class Solution {
    /**
     * In the HashMap approach we maintain a mapping:
     *
     *      originalNode → copiedNode
     *
     * This mapping allows us to easily find the copy corresponding
     * to any original node when assigning the `next` and `random` pointers.
     *
     * Example:
     *
     * originalNodeA → copiedNodeA
     * originalNodeB → copiedNodeB
     *
     * Then we set:
     *
     * copiedNodeA.next   = map.get(originalNodeA.next)
     * copiedNodeA.random = map.get(originalNodeA.random)
     *
     *
     * How this solution avoids HashMap:
     * ---------------------------------
     * Instead of storing the mapping externally in a HashMap,
     * we encode the mapping directly inside the linked list.
     *
     * We insert the copied node immediately after its original node:
     *
     * Original:
     * A → B → C
     *
     * After interleaving:
     * A → A' → B → B' → C → C'
     *
     * Now the mapping becomes implicit:
     *
     *      originalNode.next → copiedNode
     *
     * Therefore:
     *
     * copiedNode.random = originalNode.random.next
     *
     * because `originalNode.random.next` is the copied version of the
     * random node.
     *
     *
     * Steps:
     * ------
     * 1) Interleave copied nodes within the original list.
     * 2) Populate random pointers of copied nodes using the implicit mapping.
     * 3) Separate the original list and the copied list.
     *
     */
    public Node copyRandomList(Node head) {
        if (head == null) {
            return null;
        }

        // Step 1: Insert copied nodes between original nodes
        interleaveCopiedNodes(head);

        // Step 2: Assign random pointers for copied nodes
        assignRandomPointers(head);

        // Step 3: Separate original list and copied list
        return separateListsAndExtractCopy(head);
    }

    /**
     * Step 1:
     * Insert copied nodes immediately after their corresponding original nodes.
     *
     * Example:
     *
     * Before:
     * A → B → C
     *
     * After:
     * A → A' → B → B' → C → C'
     */
    private void interleaveCopiedNodes(Node head) {

        Node node = head;

        while (node != null) {
            Node nextOriginalNode = node.next;
            Node copiedNode = new Node(node.val);
            node.next = copiedNode;
            copiedNode.next = nextOriginalNode;
            node = nextOriginalNode;
        }
    }

    /**
     * Step 2:
     * Assign random pointers for the copied nodes.
     *
     * Because the copied node is always placed right after the original node,
     * the copied version of any node can be accessed using `.next`.
     *
     * Therefore:
     *
     * copiedNode.random = originalNode.random.next
     */
    private void assignRandomPointers(Node head) {

        Node node = head;

        while (node != null) {
            Node copiedNode = node.next;
            Node originalRandomNode = node.random;

            if (originalRandomNode == null) {
                copiedNode.random = null;
            } else {
                copiedNode.random = originalRandomNode.next;
            }

            // Move to the next original node
            node = copiedNode.next;
        }
    }

    /**
     * Step 3:
     * Separate the interleaved list into:
     *
     * 1) Original list
     * 2) Deep copied list
     *
     * Example:
     *
     * A → A' → B → B' → C → C'
     *
     * becomes
     *
     * Original: A → B → C
     * Copy:     A' → B' → C'
     */
    private Node separateListsAndExtractCopy(Node head) {
        Node copiedHead = head.next;

        Node originalNode = head;
        Node copiedNode = head.next;

        while (copiedNode.next != null) {
            Node nextOriginalNode = copiedNode.next;
            originalNode.next = nextOriginalNode;
            copiedNode.next = nextOriginalNode.next;
            originalNode = nextOriginalNode;
            copiedNode = copiedNode.next;
        }

        // Restore original list's final pointer
        originalNode.next = null;

        return copiedHead;
    }
}
