/**
 * Definition for singly-linked list.
 * public class ListNode {
 * int val;
 * ListNode next;
 * ListNode() {}
 * ListNode(int val) { this.val = val; }
 * ListNode(int val, ListNode next) { this.val = val; this.next = next; }
 * }
 */
 
//Bruteforce approoach

class Solution {
    /**
     * Problem:
     * Given a linked list representing a non-negative integer,
     * double the number and return the resulting linked list.
     *
     * Example:
     * 1 -> 8 -> 9
     * represents 189
     *
     * After doubling:
     * 378 -> 3 -> 7 -> 8
     *
     *
     * Core Idea:
     * ----------
     * In arithmetic operations like addition or multiplication,
     * we must start processing from the least significant digit
     * (the rightmost digit).
     *
     * However, a singly linked list can only be traversed in the
     * forward direction.
     *
     * Example:
     * 1 -> 8 -> 9
     *
     * We need to process:
     * 9 -> 8 -> 1
     *
     * Since we cannot traverse backwards in a singly linked list,
     * we reverse the list first so that the least significant digit
     * becomes the head.
     *
     * After reversing:
     *
     * 9 -> 8 -> 1
     *
     * Now we can process digits from left to right while maintaining carry,
     * exactly like manual arithmetic.
     *
     * After computing the doubled digits, we reverse the result again
     * to restore the original forward order.
     *
     */
    public ListNode doubleIt(ListNode head) {
        // Special case: if the number is 0, doubling still results in 0
        if (head.val == 0) {
            return head;
        }

        // Reverse the list so we can process digits from least significant
        ListNode node = reverse(head);

        ListNode doubledNumberHead = new ListNode(-1);
        ListNode doubledNumberTail = doubledNumberHead;

        // Carry generated during doubling
        int carry = 0;

        /*
         * Traverse the reversed list and double each digit.
         * Continue while:
         *  - there are digits left to process
         *  - OR there is still a carry remaining
         */
        while (node != null || carry == 1) {
            // Double the current digit (or 0 if node is null)
            int doubledValue = node != null ? (2 * node.val) : 0;

            // Compute resulting digit
            int newDigit = (doubledValue + carry) % 10;
            // Update carry
            carry = (doubledValue + carry) / 10;

            // Append new digit to result list
            doubledNumberTail.next = new ListNode(newDigit);
            doubledNumberTail = doubledNumberTail.next;

            // Move to next digit
            node = node != null ? node.next : null;
        }

        // Reverse the result again to restore correct order
        return reverse(doubledNumberHead.next);
    }

    private ListNode reverse(ListNode head) {
        ListNode prev = null;
        ListNode node = head;

        while (node != null) {
            ListNode next = node.next;
            node.next = prev;
            prev = node;
            node = next;
        }

        return prev;
    }
}


//Optimal approach

class Solution {
    /**
     * Improvement over the previous approach:
     *
     * Previously we:
     * 1) Reversed the input list
     * 2) Built the result list in reversed order (least significant digit first)
     * 3) Reversed the result again to restore correct forward order
     *
     * In this improved version we avoid the final reverse operation.
     *
     * Instead of appending new digits at the tail of the result list,
     * we insert each newly computed digit at the front.
     *
     * Since digits are processed from least significant to most significant
     * (because the input list was reversed), inserting at the front
     * automatically constructs the result in the correct forward order.
     *
     * This removes one full list traversal (the final reverse),
     * making the implementation slightly cleaner and more efficient.
     */
    public ListNode doubleIt(ListNode head) {
        if (head.val == 0) {
            return head;
        }

        ListNode doubledNumberHead = null;
        ListNode node = reverse(head);
        int carry = 0;

        while (node != null || carry == 1) {
            int doubledValue = node != null ? (2 * node.val) : 0;

            int newDigit = (doubledValue + carry) % 10;
            carry = (doubledValue + carry) / 10;

            ListNode digitNode = new ListNode(newDigit);

            digitNode.next = doubledNumberHead;
            doubledNumberHead = digitNode;

            node = node != null ? node.next : null;
        }

        return doubledNumberHead;
    }

    private ListNode reverse(ListNode head) {
        ListNode prev = null;
        ListNode node = head;

        while (node != null) {
            ListNode next = node.next;
            node.next = prev;
            prev = node;
            node = next;
        }

        return prev;
    }
}
