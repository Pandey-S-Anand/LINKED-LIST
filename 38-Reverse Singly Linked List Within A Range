/**
 * Definition for singly-linked list.
 * public class ListNode {
 * int val;
 * ListNode next;
 * ListNode() {}
 * ListNode(int val) { this.val = val; }
 * ListNode(int val, ListNode next) { this.val = val; this.next = next; }
 * }
 */

//Naive approach

class Solution {
    public ListNode reverseBetween(ListNode head, int left, int right) {
        // If both positions are the same, no reversal is needed
        if (left == right) { // constraint: 1 <= left <= right <= n
            return head;
        }

        // Locate the node at the right boundary
        ListNode rightNode = getNodeAt(head, right);

        // Store the node immediately after the right boundary
        ListNode rightNextNode = rightNode.next;

        // Temporarily cut the list at the right boundary . This isolates the segment [1 ... right]
        rightNode.next = null;

        /**
         * Special case: reversal starts from the head of the list.
         *
         * Segment before reversal:
         * [1 ... right]
         *
         * After reversal:
         * [right ... 1]
         *
         * - rightNode becomes the new head of this segment
         * - the original head becomes the tail
         */
        if (left == 1) {
            // Reverse the segment [1 ... right]
            reverse(head);

            // Connect the reversed segment to the remaining list on the right
            head.next = rightNextNode;

            // rightNode becomes the new head after reversal
            return rightNode;
        }

        // Find the node just before the left boundary
        ListNode leftPrevNode = getNodeAt(head, left - 1);

        // First node of the segment to be reversed
        ListNode leftNode = leftPrevNode.next;

        /**
         * Temporarily cut the list before the segment.
         *
         * Now the list is divided into two independent parts:
         *
         * [1 ... leftPrev]    [left ... right]
         */
        leftPrevNode.next = null;

        // Reverse the isolated segment
        reverse(leftNode);

        /**
         * After reversal:
         *
         * rightNode -> ... -> leftNode
         *
         * - rightNode becomes the head of the reversed segment
         * - leftNode becomes the tail of the reversed segment
         */

        // Connect the left portion of the list with the reversed segment
        leftPrevNode.next = rightNode;

        // Connect the tail of the reversed segment with the remaining right portion
        leftNode.next = rightNextNode;

        return head;
    }

    //Returns the node located at the given 1-based position.
    private ListNode getNodeAt(ListNode head, int position) {
        ListNode node = head;

        // Traverse until the required position is reached
        while (position > 1) {
            node = node.next;
            position--;
        }

        return node;
    }

    private void reverse(ListNode head) {
        // If the list contains only one node, no reversal is needed
        if (head.next == null) {
            return;
        }

        ListNode prev = null;
        ListNode node = head;

        while (node != null) {
            ListNode next = node.next;
            node.next = prev;
            prev = node;
            node = next;
        }
    }
}


//Better Approach

class Solution {
    /**
    * Improvement over the previous brute-force version:
    *
    * Previously we called `getNodeAt()` twice:
    *    1) to get the node at (right)
    *    2) to get the node at (left - 1)
    *
    * That meant two separate traversals of the list.
    *
    * In this improved version, we retrieve both required nodes
    * (`leftPrevNode` and `rightNode`) in a single traversal using
    * the helper method `getNodesAt(...)`.
    *
    * So the improvement is mainly in reducing duplicated work
    * and making the boundary node retrieval more modular.
    */
    public ListNode reverseBetween(ListNode head, int left, int right) {
        if (left == right) {
            return head;
        }

        ListNode[] nodeInfo = getNodesAt(head, left - 1, right);

        ListNode rightNode = nodeInfo[1];
        ListNode rightNextNode = rightNode.next;
        rightNode.next = null;

        if (left == 1) {
            reverse(head);

            head.next = rightNextNode;

            return rightNode;
        }

        ListNode leftPrevNode = nodeInfo[0];
        ListNode leftNode = leftPrevNode.next;

        leftPrevNode.next = null;

        reverse(leftNode);

        leftPrevNode.next = rightNode;
        leftNode.next = rightNextNode;

        return head;
    }

    private ListNode[] getNodesAt(ListNode head, int position1, int position2) {
        ListNode node = head;
        ListNode leftPrevNode = null;
        ListNode rightNode = null;
        int nodeCount = 1;

        while (node != null) {
            // Capture the node just before the left boundary
            if (nodeCount == position1) {
                leftPrevNode = node;
            } else if (nodeCount == position2) { // Capture the node at the right boundary
                rightNode = node;
            }

            /**
             * Early termination condition:
             *
             * We stop traversal as soon as the required nodes are found.
             *
             * Two possible scenarios:
             *
             * 1) left > 1
             *    We need both:
             *      - leftPrevNode  (node at position left - 1)
             *      - rightNode     (node at position right)
             *
             *    Once both are found, further traversal is unnecessary.
             *
             * 2) left == 1
             *    In this case position1 = left - 1 = 0, which means
             *    there is no node before the left boundary.
             *
             *    So leftPrevNode will never exist and the only node
             *    we actually need is rightNode.
             *
             *    Therefore we break as soon as rightNode is found.
             */
            if ((leftPrevNode != null && rightNode != null) || (position1 == 0 && rightNode != null)) {
                break;
            }

            nodeCount++;
            node = node.next;
        }

        return new ListNode[] { leftPrevNode, rightNode };
    }

    private void reverse(ListNode head) {
        if (head.next == null) {
            return;
        }

        ListNode prev = null;
        ListNode node = head;

        while (node != null) {
            ListNode next = node.next;
            node.next = prev;
            prev = node;
            node = next;
        }
    }
}


//Optimal approach

class Solution {
    /**   
     * Improvement over the previous version:
     *
     * In the earlier approach we first traversed the list to locate the
     * `right` node and only after that performed a separate reversal
     * of the segment [left ... right].
     *
     * That meant the nodes inside the segment were effectively traversed twice:
     *   1) once while searching for the `right` boundary
     *   2) again during the reversal step
     *
     * In this improved version we avoid that extra traversal.
     *
     * Once we reach the node at position `left`, we start reversing immediately
     * and continue the reversal exactly `(right - left + 1)` times.
     *
     * This means:
     *   - we do not explicitly locate the `right` node beforehand
     *   - we reverse the segment while traversing it
     *
     * So the segment [left ... right] is visited only once during reversal,
     * making the implementation slightly more efficient and simpler.
     */
    public ListNode reverseBetween(ListNode head, int left, int right) {
        // If both positions are the same, nothing needs to be reversed
        if (left == right) {
            return head;
        }

        // Get the node just before the left boundary
        ListNode leftPrevNode = getNodeAt(head, left - 1);

        // Determine the first node of the segment to be reversed
        ListNode leftNode = leftPrevNode == null ? head : leftPrevNode.next;

        // Start reversing from the left boundary
        ListNode node = leftNode;
        ListNode prev = null;

        //Reverse exactly (right - left + 1) nodes.
        while ((right - left) >= 0) {
            ListNode next = node.next;

            node.next = prev; // reverse pointer

            prev = node; // move prev forward
            node = next; // move traversal forward

            left++;
        }

        /**
         * After the loop:
         *
         * prev -> points to the node originally at position `right`
         *         (head of the reversed segment)
         *
         * node -> points to the node immediately after the reversed segment i.e rightNext
         *
         * leftNode -> now becomes the tail of the reversed segment
         */

        // Connect the tail of the reversed segment to the remaining right portion
        leftNode.next = node;

        // If reversal started from the head of the list
        if (leftPrevNode == null) {
            return prev;
        }

        // Connect the left portion with the head of the reversed segment
        leftPrevNode.next = prev;

        return head;
    }

    /**
     * Returns the node located at the given 1-based position.
     * If position < 1, returns null.
     */
    private ListNode getNodeAt(ListNode head, int position) {
        if (position < 1) {
            return null;
        }

        ListNode node = head;

        while (position > 1) {
            node = node.next;
            position--;
        }

        return node;
    }
}
