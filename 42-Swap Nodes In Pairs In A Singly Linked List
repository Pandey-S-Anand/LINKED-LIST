/**
 * Definition for singly-linked list.
 * public class ListNode {
 * int val;
 * ListNode next;
 * ListNode() {}
 * ListNode(int val) { this.val = val; }
 * ListNode(int val, ListNode next) { this.val = val; this.next = next; }
 * }
 */

class Solution {
    public ListNode swapPairs(ListNode head) {
        /*
         * Base case:
         * If the list is empty or contains only one node,
         * no swapping can be performed.
         */
        if (head == null || head.next == null) {
            return head;
        }

        /*
         * After the first swap:
         * Example:
         * 1 → 2 → 3 → 4
         *
         * First pair becomes:
         * 2 → 1
         *
         * So the second node becomes the new head.
         */
        ListNode newHead = head.next;

        /*
         * pairHead  → head of the current pair
         * pairTail  → second node of the pair (which becomes the head after swap)
         * lastPairTail → tail of the previously processed pair, used to connect pairs together
         */
        ListNode pairHead = head;
        ListNode pairTail = head.next;
        ListNode lastPairTail = null;

        /*
         * Traverse the list pair by pair.
         * pairHead → first node of pair
         * pairTail → second node of pair
         */
        while (pairTail != null) {
            // Save the head of the next pair before breaking links.
            ListNode nextPairHead = pairTail.next;

            /*
             * Temporarily break the link between the current pair tail
             * and the rest of the list so that we can swap safely.
             */
            pairTail.next = null;

            /*
             * Swap the current pair.
             *
             * Before swap:
             * pairHead → pairTail -> null
             *
             * After swap:
             * pairTail → pairHead -> null
             */
            swap(pairHead);

            /*
             * After swapping:
             *
             * pairTail → new head of this pair
             * pairHead → new tail of this pair
             *
             * Connect the previous pair with the current pair.
             */
            if (lastPairTail != null) {
                lastPairTail.next = pairTail;
            }

            /*
             * Update lastPairTail because pairHead is now
             * the tail of the swapped pair.
             */
            lastPairTail = pairHead;

            // Move to the next pair.
            pairHead = nextPairHead;
            pairTail = nextPairHead != null ? nextPairHead.next : null;
        }

        /*
         * If the list has an odd number of nodes,
         * one node will remain unswapped.
         *
         * Example:
         * 1 → 2 → 3
         *
         * Result:
         * 2 → 1 → 3
         *
         * So attach the leftover node to the last swapped pair tail.
         */
        if (pairHead != null) {
            lastPairTail.next = pairHead;
        }

        return newHead;
    }

    private void swap(ListNode head) {
        /*
         * Swap two nodes:
         *
         * first → second -> null
         *
         * becomes
         *
         * second → first -> null
         */
        ListNode first = head;
        ListNode second = head.next;

        second.next = first;
        first.next = null;
    }
}
