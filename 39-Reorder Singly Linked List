/**
 * Definition for singly-linked list.
 * public class ListNode {
 * int val;
 * ListNode next;
 * ListNode() {}
 * ListNode(int val) { this.val = val; }
 * ListNode(int val, ListNode next) { this.val = val; this.next = next; }
 * }
 */

class Solution {
    public void reorderList(ListNode head) {
        // If the list contains only one node, reordering is unnecessary
        if (head.next == null) {
            return;
        }

        // Split the list into two halves. The method returns the head of the second half
        ListNode middle = findMiddle(head);

        // Reverse the second half. This allows us to pick nodes from the end easily
        ListNode tail = reverse(middle);

        //Merge the first half and reversed second half alternately
        rearrange(head, tail);
    }

    private ListNode findMiddle(ListNode head) {
        ListNode slow = head;
        ListNode fast = head;

        // This pointer will track the node before slow so we can break the list into two halves
        ListNode slowPrev = null;

        while (fast != null && fast.next != null) {
            slowPrev = slow;
            slow = slow.next;
            fast = fast.next.next;
        }

        /*
         * At this point:
         * slow -> start of second half
         * slowPrev -> last node of first half
         *
         * Break the list into two independent lists
         */
        slowPrev.next = null;

        return slow;
    }

    private ListNode reverse(ListNode head) {
        if (head.next == null) {
            return head;
        }

        ListNode node = head;
        ListNode prev = null;

        while (node != null) {
            ListNode next = node.next;
            node.next = prev;
            prev = node;
            node = next;
        }

        // prev becomes the new head of the reversed list
        return prev;
    }

    /*
     * After splitting and reversing:
     *
     * Case 1: Even length list
     *
     * Example:
     * 1 -> 2 -> 3 -> 4 -> 5 -> 6
     *
     * left half  = 1 -> 2 -> 3
     * right half = 4 -> 5 -> 6
     *
     * reversed right = 6 -> 5 -> 4
     *
     * merge result:
     * 1 -> 6 -> 2 -> 5 -> 3 -> 4
     *
     *
     * Case 2: Odd length list
     *
     * Example:
     * 1 -> 2 -> 3 -> 4 -> 5
     *
     * left half  = 1 -> 2
     * right half = 3 -> 4 -> 5
     *
     * reversed right = 5 -> 4 -> 3
     *
     * merge result:
     * 1 -> 5 -> 2 -> 4 -> 3
     *
     * Notice:
     * The right half contains one extra node.
     *
     * That node should remain at the end of the final list.
     */
    private void rearrange(ListNode head1, ListNode head2) {
        // node1 traverses the first half
        ListNode node1 = head1;
        // node2 traverses the reversed second half
        ListNode node2 = head2;

        while (node1 != null) {
            // Save next pointers before modifying links
            ListNode next1 = node1.next;
            ListNode next2 = node2.next;

            // Insert node from second half after node1
            node1.next = node2;

            /*
             * For odd length lists,
             * the right half has one extra node.
             *
             * When next1 becomes null,
             * we must avoid connecting node2.next to next1
             * because next1 is null.
             *
             * This ensures the last node of the right half
             * remains correctly placed at the end.
             */
            if (next1 != null) {
                node2.next = next1;
            }

            // Move both pointers forward
            node1 = next1;
            node2 = next2;
        }
    }
}
