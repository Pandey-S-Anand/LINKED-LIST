/**
 * Definition for singly-linked list.
 * public class ListNode {
 * int val;
 * ListNode next;
 * ListNode() {}
 * ListNode(int val) { this.val = val; }
 * ListNode(int val, ListNode next) { this.val = val; this.next = next; }
 * }
 */

//Bruteforce approach

class Solution {
    /**
     * Adds two numbers represented by linked lists where
     * digits are stored in FORWARD order.
     *
     * Example:
     *   7243 is stored as:
     *   7 → 2 → 4 → 3
     *
     * Direct addition from head is difficult because:
     * - Addition must start from the least significant digit (rightmost).
     * - But singly linked lists only allow traversal from left → right.
     *
     * ------------------------------------------------------------
     * Brute Force Idea:
     *
     * 1) Reverse both lists so that least significant digit comes first.
     *
     *      7 → 2 → 4 → 3
     *  becomes
     *      3 → 4 → 2 → 7
     *
     * 2) Perform normal digit-by-digit addition
     *    (same logic used when digits are already stored in reverse order).
     *
     * 3) The resulting sum list will also be in reverse order,
     *    so reverse it again to restore the correct forward order.
     *
     * ------------------------------------------------------------
     * Example:
     *
     *   7243
     * + 564
     *
     * After reversing:
     *
     *   3 → 4 → 2 → 7
     * + 4 → 6 → 5
     *
     * Result (reverse order):
     *   7 → 0 → 8 → 7
     *
     * Reverse again:
     *   7 → 8 → 0 → 7
     *
     */
    public ListNode addTwoNumbers(ListNode head1, ListNode head2) {
        // Reverse both lists so addition can start from least significant digit
        head1 = reverse(head1);
        head2 = reverse(head2);

        // Perform addition on reversed lists
        ListNode result = sumTwoNumbers(head1, head2);

        // Reverse result to restore forward order
        return reverse(result);
    }

    private ListNode sumTwoNumbers(ListNode head1, ListNode head2) {
        ListNode head = new ListNode(-1);
        ListNode tail = head;

        ListNode node1 = head1;
        ListNode node2 = head2;

        int carry = 0;

        /**
         * Continue while:
         * - digits remain in either list, OR
         * - carry is still present.
         */
        while (node1 != null || node2 != null || carry == 1) {

            int digit1 = node1 != null ? node1.val : 0;
            int digit2 = node2 != null ? node2.val : 0;

            int sum = digit1 + digit2 + carry;

            int newDigit = sum % 10;
            carry = sum / 10;

            // Append resulting digit
            tail.next = new ListNode(newDigit);
            tail = tail.next;

            // Move forward in lists if possible
            node1 = node1 != null ? node1.next : null;
            node2 = node2 != null ? node2.next : null;
        }

        // Skip dummy node
        return head.next;
    }

    private ListNode reverse(ListNode head) {
        // Single node list remains unchanged
        if (head.next == null) {
            return head;
        }

        ListNode prev = null;
        ListNode node = head;

        while (node != null) {
            ListNode next = node.next; // Save next node
            node.next = prev; // Reverse link
            prev = node; // Move prev forward
            node = next; // Continue traversal
        }

        // 'prev' becomes new head
        return prev;
    }
}


//Optimal approach

class Solution {
    /**
     * Brute Force Improvement:
     *
     * We reverse both input lists so that addition can start from the
     * least significant digit (rightmost digit).
     *
     * Unlike the previous brute force solution, we DO NOT reverse the
     * result list at the end.
     *
     * Instead, during addition we insert every newly computed digit
     * at the FRONT of the result list.
     *
     * This automatically reconstructs the final number in forward order.
     *
     * Example:
     *   7243 + 564
     *
     * After reversing inputs:
     *   3 → 4 → 2 → 7
     * + 4 → 6 → 5
     *
     * Digits produced (LSB → MSB):
     *   7, 0, 8, 7
     *
     * By inserting at the head each time:
     *
     * step1: 7
     * step2: 0 → 7
     * step3: 8 → 0 → 7
     * step4: 7 → 8 → 0 → 7
     *
     * The result is already in correct forward order,
     * eliminating the need for a final reversal.
     */
    public ListNode addTwoNumbers(ListNode head1, ListNode head2) {
        head1 = reverse(head1);
        head2 = reverse(head2);

        return sumTwoNumbers(head1, head2);
    }

    private ListNode sumTwoNumbers(ListNode head1, ListNode head2) {
        ListNode head = null;

        ListNode node1 = head1;
        ListNode node2 = head2;

        int carry = 0;

        while (node1 != null || node2 != null || carry == 1) {
            int digit1 = node1 != null ? node1.val : 0;
            int digit2 = node2 != null ? node2.val : 0;

            int sum = digit1 + digit2 + carry;

            int newDigit = sum % 10;
            carry = sum / 10;

            /**
             * Key Improvement:
             * Insert the new digit at the FRONT of the result list.
             *
             * This builds the number in correct forward order
             * without needing a final reverse operation.
             */
            ListNode newNode = new ListNode(newDigit);
            newNode.next = head;
            head = newNode;

            node1 = node1 != null ? node1.next : null;
            node2 = node2 != null ? node2.next : null;
        }

        return head;
    }

    private ListNode reverse(ListNode head) {
        if (head.next == null) {
            return head;
        }

        ListNode prev = null;
        ListNode node = head;

        while (node != null) {
            ListNode next = node.next;
            node.next = prev;
            prev = node;
            node = next;
        }

        return prev;
    }
}


//Aliter (without reversing the list)

class Solution {
    /**
     * Adds two numbers represented by singly linked lists where
     * digits are stored in FORWARD order.
     *
     * Example:
     *   7243  →  7 → 2 → 4 → 3
     * + 564   →  5 → 6 → 4
     *
     * Direct addition from head is difficult because addition must start
     * from the least significant digit (rightmost), but a singly linked list
     * only allows traversal from left to right.
     *
     * ------------------------------------------------------------
     * Approach (Stack-Based Solution)
     *
     * 1) Push all digits from both lists into two stacks.
     *    This reverses the access order so that the least
     *    significant digits are processed first.
     *
     *    Example stacks:
     *
     *    stack1 (top → bottom): 3,4,2,7
     *    stack2 (top → bottom): 4,6,5
     *
     * 2) Pop digits from both stacks and perform standard
     *    digit-by-digit addition with carry.
     *
     * 3) Each computed digit is inserted at the FRONT of the
     *    result list so that the final number remains in
     *    forward order.
     *
     */
    public ListNode addTwoNumbers(ListNode head1, ListNode head2) {
        ListNode head = null;

        // Stacks to simulate reverse traversal of the lists
        Deque<Integer> digitsStack1 = new ArrayDeque<>();
        Deque<Integer> digitsStack2 = new ArrayDeque<>();

        ListNode node1 = head1;
        ListNode node2 = head2;

        /**
         * Push digits of both lists into stacks.
         * This allows us to process digits starting
         * from the least significant position.
         */
        while (node1 != null || node2 != null) {
            if (node1 != null) {
                digitsStack1.push(node1.val);
                node1 = node1.next;
            }

            if (node2 != null) {
                digitsStack2.push(node2.val);
                node2 = node2.next;
            }
        }

        int carry = 0;

        /**
         * Pop digits from stacks and perform addition.
         *
         * Continue while:
         * - digits remain in either stack
         * - or a carry remains
         */
        while (!digitsStack1.isEmpty() || !digitsStack2.isEmpty() || carry == 1) {
            int digit1 = !digitsStack1.isEmpty() ? digitsStack1.pop() : 0;
            int digit2 = !digitsStack2.isEmpty() ? digitsStack2.pop() : 0;

            int sum = digit1 + digit2 + carry;

            int newDigit = sum % 10;
            carry = sum / 10;

            /**
             * Insert the new digit at the front of the result list.
             * This maintains the correct forward order of digits.
             */
            ListNode newNode = new ListNode(newDigit);
            newNode.next = head;
            head = newNode;
        }

        return head;
    }
}
