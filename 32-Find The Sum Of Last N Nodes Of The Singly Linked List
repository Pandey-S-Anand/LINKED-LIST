//Bruteforce Approach

class Solution {
    /**
     * Approach:
     * 1) Compute the total length (L) of the linked list.
     * 2) The last 'n' nodes start at index (L - n) from the head (0-based indexing).
     * 3) Traverse to that node.
     * 4) Sum all nodes from that position until the end of the list.
     *
     * Example:
     * List: 1 → 2 → 3 → 4 → 5 → 6
     * n = 3
     *
     * length = 6
     * startIndex = 6 - 3 = 3
     *
     * Node at index 3 → value = 4
     *
     * Sum = 4 + 5 + 6 = 15
     */
    public int sumOfLastN_Nodes(Node head, int n) {
        // Determine the starting index of the last 'n' nodes
        int targetIndex = getLength(head) - n;

        // Retrieve the node where the last 'n' nodes begin
        Node startNode = getNodeAt(head, targetIndex);

        // Compute the sum from that node until the end
        return sumOfNodes(startNode);
    }

    //Computes the total number of nodes in the linked list.
    private int getLength(Node head) {
        Node node = head;
        int length = 0;

        while (node != null) {
            node = node.next;
            length++;
        }

        return length;
    }

    // Returns the node at the given index (0-based).
    private Node getNodeAt(Node head, int index) {
        Node node = head;

        while (index > 0) {
            node = node.next;
            index--;
        }

        return node;
    }

    private int sumOfNodes(Node node) {
        int sum = 0;

        while (node != null) {
            sum += node.data;
            node = node.next;
        }

        return sum;
    }
}

//Optimal approach

class Solution {
    public int sumOfLastN_Nodes(Node head, int n) {
        //Find the Nth node from the end of the list
        Node nthNode = getNthNodeFromEnd(head, n);
        //Calculate the sum of all nodes from the Nth node to the end
        return sumOfLastNNodes(nthNode);
    }

    private Node getNthNodeFromEnd(Node head, int n) {
        // Initialize two pointers, `fast` and `slow`, both starting at the head
        Node fast = head;
        Node slow = head;

        // Move the `fast` pointer n steps ahead
        for (int i = 1; i <= n; i++) {
            fast = fast.next;
        }

        // If `fast` becomes null after moving n steps, it means the Nth node from the end is the head node itself
        if (fast == null) {
            return head; // Return the head node
        }

        // Move both `fast` and `slow` pointers until `fast` reaches the end : When `fast` becomes null, the `slow` will point to the Nth node from the end
        while (fast != null) {
            fast = fast.next;
            slow = slow.next;
        }

        // Return the Nth node from the end
        return slow;
    }

    private int sumOfLastNNodes(Node node) {
        int sum = 0;
        while (node != null) {
            sum += node.data;
            node = node.next;
        }

        return sum;
    }
}
