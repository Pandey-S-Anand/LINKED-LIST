/**
 * Definition for singly-linked list.
 * public class ListNode {
 * int val;
 * ListNode next;
 * ListNode() {}
 * ListNode(int val) { this.val = val; }
 * ListNode(int val, ListNode next) { this.val = val; this.next = next; }
 * }
 */

 //Bruteforce approach

class Solution {
    public int[] nodesBetweenCriticalPoints(ListNode head) {
        // Get positions of all critical points in the linked list
        List<Integer> criticalPointPositions = getCriticalPointPositions(head);

        // If fewer than two critical points exist, distance cannot be computed
        if (criticalPointPositions.size() <= 1) {
            return new int[] { -1, -1 };
        }

        /*
         * Since we traverse the linked list from left to right and store the
         * positions as we encounter them, the positions in this list are
         * naturally stored in sorted order.
         *
         * Therefore:
         * - The maximum distance will always be between the first and last critical points.
         */
        int maxDistance = criticalPointPositions.get(criticalPointPositions.size() - 1) - criticalPointPositions.get(0);

        /*
         * Minimum distance must occur between two adjacent critical points
         * because the list is already sorted.
         *
         * We simply compute the smallest difference between consecutive
         * positions.
         */
        int minDistance = Integer.MAX_VALUE;

        for (int i = 1; i < criticalPointPositions.size(); i++) {
            int distance = criticalPointPositions.get(i) - criticalPointPositions.get(i - 1);
            minDistance = Math.min(minDistance, distance);
        }

        // Return result in required format [minDistance, maxDistance]
        return new int[] { minDistance, maxDistance };
    }

    private List<Integer> getCriticalPointPositions(ListNode head) {
        List<Integer> criticalPointPositions = new ArrayList<>();

        /*
         * The first and last nodes of a linked list can never be critical points
         * because a critical point must have both a previous and a next node.
         *
         * Therefore we start checking from the second node and stop before the last node.
         */
        ListNode prev = head;
        ListNode node = head.next;

        int position = 2; // node currently represents the 2nd node in the list

        while (node.next != null) {
            int currVal = node.val;
            int prevVal = prev.val;
            int nextVal = node.next.val;

            /*
             * A critical point occurs when the current node is either:
             * 1) Local minima  -> smaller than both neighbors
             * 2) Local maxima  -> larger than both neighbors
             */
            if (isLocalMinimaOrMaxima(currVal, prevVal, nextVal)) {
                criticalPointPositions.add(position);
            }

            // Move traversal pointers forward
            prev = node;
            node = node.next;
            position++;
        }

        return criticalPointPositions;
    }

    private boolean isLocalMinimaOrMaxima(int currVal, int prevVal, int nextVal) {
        return ((currVal < prevVal && currVal < nextVal) || (currVal > prevVal && currVal > nextVal));
    }
}


//Optimal approach

class Solution {
    /**
     * The problem asks us to compute:
     *
     * 1) Minimum distance between any two critical points
     * 2) Maximum distance between any two critical points
     *
     *
     * Key Observations:
     * -----------------
     * 1) The maximum distance between critical points will always be
     *    between the FIRST and the LAST critical point encountered.
     *
     * 2) The minimum distance between critical points will always occur
     *    between two ADJACENT critical points.
     *
     *
     * Therefore we do NOT need to store all critical point positions.
     *
     * Instead we only keep track of:
     *
     * - firstCriticalPointPosition → position of the first critical point
     * - prevCriticalPointPosition  → position of the previous critical point
     *
     * While traversing the list we:
     *
     * - Update minDistance using distance between current and previous critical point
     * - Update prevCriticalPointPosition to the current position
     *
     *
     * After traversal finishes:
     *
     * - prevCriticalPointPosition will hold the LAST critical point position
     * - firstCriticalPointPosition will hold the FIRST critical point position
     *
     * Thus:
     *
     * maxDistance = lastCriticalPosition - firstCriticalPosition
     *
     *
     * Time Complexity:
     * O(n)
     *
     * Space Complexity:
     * O(1)
     */

    public int[] nodesBetweenCriticalPoints(ListNode head) {
        // Stores the position of the first critical point encountered
        int firstCriticalPointPosition = -1;
        // Stores the position of the previous critical point encountered
        int prevCriticalPointPosition = -1;

        /*
         * Start traversal from the second node.
         * The first node cannot be a critical point because it does not
         * have a left neighbour. 
         */
        ListNode prev = head;
        ListNode node = head.next;

        // Current node is at position 2 
        int position = 2;

        // Stores minimum distance between adjacent critical points
        int minDistance = Integer.MAX_VALUE;

        /**
         * We stop before the last node because the last node cannot
         * be a critical point (it does not have a right neighbor).
         */
        while (node.next != null) {
            // Check if current node is a local minima or maxima.
            if (isLocalMinimaOrMaxima(node.val, prev.val, node.next.val)) {
                /**
                 * If this is the first critical point we encounter,
                 * initialize both trackers.
                 */
                if (firstCriticalPointPosition == -1) {
                    firstCriticalPointPosition = prevCriticalPointPosition = position;
                } else {
                    /**
                    * Otherwise compute distance from the previous
                    * critical point and update minimum distance.
                    */
                    int distance = position - prevCriticalPointPosition;
                    minDistance = Math.min(minDistance, distance);
                    prevCriticalPointPosition = position;
                }
            }

            // Move traversal forward
            position++;
            prev = node;
            node = node.next;
        }

        /**
         * If fewer than two critical points exist,
         * the answer must be [-1, -1].
         */
        if (firstCriticalPointPosition == -1 || prevCriticalPointPosition == -1) {
            return new int[] { -1, -1 };
        }

        /**
         * At this point:
         *
         * firstCriticalPointPosition → first critical point
         * prevCriticalPointPosition  → last critical point
         *
         * So maximum distance is simply their difference.
         */
        int maxDistance = prevCriticalPointPosition - firstCriticalPointPosition;

        return new int[] { minDistance, maxDistance };
    }

    private boolean isLocalMinimaOrMaxima(int currVal, int prevVal, int nextVal) {
        return ((currVal < prevVal && currVal < nextVal) || (currVal > prevVal && currVal > nextVal));
    }
}
