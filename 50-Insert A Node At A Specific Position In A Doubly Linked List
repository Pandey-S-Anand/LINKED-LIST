/*
class Node
{
    int data;
    Node next;
    Node prev;
    Node(int data)
    {
        this.data = data;
        next = prev = null;
    }
}
*/

class Solution {
    Node insertAtPos(Node head, int index, int data) {
        // Find the node at the given index
        Node targetNode = getNodeAt(head, index);

        // Create the new node to be inserted
        Node newNode = new Node(data);

        // Save the next node because we will modify targetNode.next.
        Node next = targetNode.next;

        //Connect targetNode to newNode
        targetNode.next = newNode;
        newNode.prev = targetNode;

        // Connect newNode to the original next node
        newNode.next = next;

        /*
         * If next exists, fix its prev pointer
         *
         * After insertion:
         * targetNode <-> newNode <-> next
         */
        if (next != null) {
            next.prev = newNode;
        }

        // Head remains unchanged since insertion happens after index
        return head;
    }

    private Node getNodeAt(Node head, int index) {
        Node node = head;

        // Traverse until the required index is reached
        while (index != 0) {
            node = node.next;
            index--;
        }

        return node;
    }
}
