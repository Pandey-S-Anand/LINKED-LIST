class Solution {
    public static ArrayList<ArrayList<Integer>> findPairsWithGivenSum(int targetSum, Node head) {
        // If the list has fewer than 2 nodes, no pair can exist
        if (head.next == null) {
            return new ArrayList<>();
        }

        // Stores all valid pairs found
        ArrayList<ArrayList<Integer>> pairs = new ArrayList<>();

        // Left pointer starts from the smallest value
        Node left = head;

        // Right pointer starts from the largest value
        Node right = getTail(head);

        /**
         * Continue until pointers meet or cross each other.
         *
         * left != right
         *     → handles odd length lists where pointers meet
         *
         * left.prev != right
         *     → handles even length lists where pointers cross
         */
        while (left != right && left.prev != right) {
            int pairSum = left.data + right.data;

            // Case 1: Found a valid pair
            if (pairSum == targetSum) {
                pairs.add(new ArrayList<>(List.of(left.data, right.data)));

                // Move both pointers inward to look for new pairs
                left = left.next;
                right = right.prev;
            } else if (pairSum < targetSum) { // Case 2: Sum is smaller than required → increase sum
                left = left.next;
            } else { // Case 3: Sum is larger than required → decrease sum
                right = right.prev;
            }
        }

        return pairs;
    }

    // Returns the last node (tail) of the doubly linked list.
    private static Node getTail(Node head) {
        Node node = head;

        // Traverse until we reach the last node
        while (node.next != null) {
            node = node.next;
        }

        return node;
    }
}
