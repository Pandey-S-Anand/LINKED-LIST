/**
 * Definition for singly-linked list.
 * public class ListNode {
 * int val;
 * ListNode next;
 * ListNode() {}
 * ListNode(int val) { this.val = val; }
 * ListNode(int val, ListNode next) { this.val = val; this.next = next; }
 * }
 */

//Bruteforce approach
 
class Solution {
    public ListNode rotateRight(ListNode head, int k) {
        // Edge case: empty list or single node list
        if (head == null || head.next == null) {
            return head;
        }

        int length = getLength(head);

        /**
         * Optimization:
         * Rotating the list by its length results in the same list.
         *
         * Example:
         * List: 1 → 2 → 3 → 4 → 5
         * length = 5
         *
         * rotate by 5 → same list
         * rotate by 10 → same list
         * rotate by 15 → same list
         *
         * Therefore, rotating by k positions is equivalent to
         * rotating by (k % length).
         *
         * This prevents unnecessary rotations when k is very large.
         *
         * Example:
         * k = 12, length = 5
         *
         * 12 % 5 = 2
         *
         * So rotating 12 times is the same as rotating only 2 times.
         */
        k = k % length;

        // Perform k single right rotations
        while (k > 0) {
            head = rotateRightByOne(head);
            k--;
        }

        return head;
    }

    private ListNode rotateRightByOne(ListNode head) {
        ListNode prevToTail = null; // Will store the node before the last node
        ListNode node = head;

        // Traverse until we reach the last node
        while (node.next != null) {
            prevToTail = node;
            node = node.next;
        }

        // Break the link between second-last node and last node
        prevToTail.next = null;

        // Move the last node to the front
        node.next = head;

        // Old tail becomes the new head
        return node;
    }

    private int getLength(ListNode head) {
        ListNode node = head;
        int length = 0;

        while (node != null) {
            length++;
            node = node.next;
        }

        return length;
    }
}


//Optimal Approach

class Solution {
    /**
     * Core Intuition:
     *
     * A right rotation by k moves the last k nodes of the list to the front.
     * Therefore, the list must be split just before the kth node from the end.
     *
     * Example:
     * 1 → 2 → 3 → 4 → 5,  k = 2
     *
     * Last k nodes:
     * 4 → 5
     *
     * After rotation:
     * 4 → 5 → 1 → 2 → 3
     *
     * Hence:
     * - The node just before the kth node from the end becomes the new tail.
     * - The kth node from the end becomes the new head.
     */
    public ListNode rotateRight(ListNode head, int k) {

        // Edge case: if the list is empty or has only one node, rotating it will not change the structure.
        if (head == null || head.next == null) {
            return head;
        }

        int length = getLength(head);

        /**
         * Rotating a list by its length results in the same list.
         *
         * Example:
         * length = 5
         * rotate by 5  → same list
         * rotate by 10 → same list
         *
         * Therefore only the remainder rotations matter.
         */
        k = k % length;

        // If the effective rotation count becomes 0,
        // the list remains unchanged.
        if (k == 0) {
            return head;
        }

        /**
         * Find two important nodes in one traversal:
         *
         * 1) The node just before the kth node from the end → newTail
         * 2) The last node of the list → oldTail
         *
         * These are sufficient to perform the rotation.
         */
        ListNode[] info = findPrevToKthFromEndAndTail(head, k);

        ListNode newTail = info[0];
        ListNode oldTail = info[1];

        // The kth node from the end becomes the new head
        ListNode kthNodeFromEnd = newTail.next;

        // Break the list at the new tail
        newTail.next = null;

        // Attach the old tail to the original head
        oldTail.next = head;

        // Return the new head of the rotated list
        return kthNodeFromEnd;
    }

    private int getLength(ListNode head) {
        int length = 0;
        ListNode node = head;

        while (node != null) {
            node = node.next;
            length++;
        }

        return length;
    }

    private ListNode[] findPrevToKthFromEndAndTail(ListNode head, int k) {
        ListNode fast = head;
        ListNode slow = head;

        /**
         * Advance fast pointer by k steps.
         *
         * Why this is safe:
         * - If k == length, fast would become null.
         * - But we already ensured k < length using k % length.
         *
         * Therefore k is always in range:
         *      0 ≤ k ≤ length - 1
         *
         * So fast will always land on a valid node and never become null here.
         */
        while (k > 0) {
            fast = fast.next;
            k--;
        }

        /**
         * Move both pointers together until fast reaches the last node.
         *
         * Since fast started k nodes ahead of slow, the gap between them
         * always remains k nodes.
         *
         * When fast reaches the last node:
         *
         * fast → last node (tail)
         * slow → node just before the kth node from the end
         */
        while (fast.next != null) {
            slow = slow.next;
            fast = fast.next;
        }

        return new ListNode[] { slow, fast };
    }
}
