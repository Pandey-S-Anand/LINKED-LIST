class Solution {
    public Node delPos(Node head, int position) {
        /*
         * Special case: deleting the head node.
         *
         * If position == 1, we move the head forward
         * and remove the backward link from the new head.
         */
        if (position == 1) {
            Node newHead = head.next;

            // If the list had more than one node
            if (newHead != null) {
                newHead.prev = null;
            }

            return newHead;
        }

        // Find the node located at the given position.
        Node targetNode = getNodeAt(head, position);

        // Neighbor nodes of the node being deleted
        Node prevNode = targetNode.prev;
        Node nextNode = targetNode.next;

        /*
         * Connect the previous node to the next node,
         * bypassing the target node.
         */
        prevNode.next = nextNode;

        /*
         * If the next node exists, update its prev pointer
         * to maintain the DLL structure.
         */
        if (nextNode != null) {
            nextNode.prev = prevNode;
        }

        // Fully disconnect the target node from the list.
        targetNode.next = null;
        targetNode.prev = null;

        // Head remains unchanged for all non-head deletions
        return head;
    }

    private Node getNodeAt(Node head, int position) {
        Node node = head;

        // Traverse until the desired position is reached
        while (position != 1) {
            node = node.next;
            position--;
        }

        return node;
    }
}
