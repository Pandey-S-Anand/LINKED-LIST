/**
 * Definition for singly-linked list.
 * public class ListNode {
 * int val;
 * ListNode next;
 * ListNode() {}
 * ListNode(int val) { this.val = val; }
 * ListNode(int val, ListNode next) { this.val = val; this.next = next; }
 * }
 */

class Solution {
    /**
     * Problem:
     * The linked list starts and ends with 0.
     * Between every two consecutive 0s there are values that must be summed.
     *
     * Example:
     * 0 -> 3 -> 1 -> 0 -> 4 -> 5 -> 2 -> 0
     *
     * Segments:
     * (3 + 1) = 4
     * (4 + 5 + 2) = 11
     *
     * Result:
     * 4 -> 11
     *
     *
     * Approach:
     * Traverse the list while accumulating the sum of nodes between two zeros.
     *
     * When we encounter a zero:
     * - it means the current segment has ended
     * - we create a new node containing the computed segment sum
     * - append it to the result list
     * - reset the sum for the next segment
     *
     */
    public ListNode mergeNodes(ListNode head) {
        ListNode mergedHead = new ListNode(-1);
        ListNode mergedTail = mergedHead;

        /*
         * Start traversal from the second node.
         *
         * The first node is guaranteed to be 0 according to the problem statement,
         * we skip it and start processing from head.next.
         */
        ListNode node = head.next;

        // Stores the running sum of values between two zeros
        int segmentSum = 0;

        while (node != null) {
            /*
             * When we encounter a zero, it indicates the end of the current segment.
             * The accumulated sum represents the merged value of that segment.
             */
            if (node.val == 0) {
                // Create a new node containing the segment sum
                ListNode newNode = new ListNode(segmentSum);

                // Reset sum for the next segment
                segmentSum = 0;

                // Append the new node to the result list
                mergedTail.next = newNode;
                mergedTail = mergedTail.next;
            } else {
                /*
                * Otherwise we are still inside a segment,
                * so keep accumulating the sum.
                */
                segmentSum += node.val;
            }

            // Move to the next node in the list
            node = node.next;
        }

        // Skip dummy node and return actual result head
        return mergedHead.next;
    }
}
