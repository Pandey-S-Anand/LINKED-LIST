/**
 * Definition for singly-linked list.
 * public class ListNode {
 * int val;
 * ListNode next;
 * ListNode() {}
 * ListNode(int val) { this.val = val; }
 * ListNode(int val, ListNode next) { this.val = val; this.next = next; }
 * }
 */


//Bruteforce approach
 
class Solution {
    public ListNode removeNodes(ListNode head) {
        ListNode node = head;

        ListNode resultHead = new ListNode(-1);
        ListNode resultTail = resultHead;

        // Traverse the list
        while (node != null) {
            ListNode next = node.next;

            /**
             * If no greater node exists on the right side,
             * keep this node in the result list.
             */
            if (!hasGreaterOnRight(node)) {
                resultTail.next = node;
                resultTail = resultTail.next;
                // Disconnect node from original list to avoid unwanted links
                node.next = null;
            }

            node = next;
        }

        // Return the head of the filtered list
        return resultHead.next;
    }

    /**
     * Checks whether there exists a node with a greater value
     * anywhere to the right of the given node.
     */
    private boolean hasGreaterOnRight(ListNode head) {
        ListNode node = head.next;

        // Scan the remaining list
        while (node != null) {
            // If a greater value is found, this node must be removed
            if (node.val > head.val) {
                return true;
            }

            node = node.next;
        }

        // No greater value exists on the right
        return false;
    }
}


//Optimal approach

class Solution {
    /*
     *
     * We must remove every node that has a greater value somewhere to its RIGHT.
     *
     * Example:
     * 1 -> 2 -> 13 -> 3 -> 8
     *
     * Node 1 has greater value (2,13,3,8) on its right → remove
     * Node 2 has greater value (13) on its right → remove
     * Node 13 has no greater value on right → keep
     * Node 3 has greater value (8) on its right → remove
     * Node 8 has no greater value on right → keep
     *
     * Result:
     * 13 -> 8
     *
     *
     * Key Idea:
     *
     * The condition requires us to check values on the RIGHT side.
     * However, a singly linked list only allows forward traversal,
     * so we cannot efficiently inspect nodes to the right while
     * traversing from left to right.
     *
     * To solve this, we reverse the list.
     *
     * After reversing:
     *
     * 1 -> 2 -> 13 -> 3 -> 8
     * becomes
     * 8 -> 3 -> 13 -> 2 -> 1
     *
     * Now the "right side" of the original list becomes the "left side"
     * of the reversed list.
     *
     * So the problem transforms into:
     *
     * Remove every node that has a greater value on the LEFT side.
     *
     * This can be solved easily by maintaining a running maximum
     * while traversing the reversed list.
     *
     * If a node value is smaller than the maximum seen so far,
     * it means there exists a greater value to its right in the
     * original list → so we remove it.
     *
     * After processing, we reverse the list again to restore the
     * original ordering direction.
     */
    public ListNode removeNodes(ListNode head) {
        // Reverse the list so that "right side" becomes "left side"
        ListNode tail = reverse(head);

        ListNode node = tail;
        ListNode prev = null;

        // Track the maximum value seen so far while traversing
        int maxSoFar = tail.val;

        while (node != null) {
            /*
            * If the current node's value is smaller than the maximum value
            * encountered so far while traversing the reversed list,
            * it means that in the original list there existed a node
            * with a greater value somewhere to its right.
            *
            * Therefore, this node must be removed according to the
            * problem requirement.
            */
            if (node.val < maxSoFar) {
                ListNode next = node.next;
                prev.next = next;
                node.next = null;
                node = next;
            } else {
                // Update maxSoFar and continue traversal
                maxSoFar = Math.max(maxSoFar, node.val);
                prev = node;
                node = node.next;
            }
        }

        // Reverse the list again to restore original direction
        return reverse(tail);
    }

    private ListNode reverse(ListNode head) {
        if (head.next == null) {
            return head;
        }

        ListNode prev = null;
        ListNode node = head;

        while (node != null) {
            ListNode next = node.next;
            node.next = prev;
            prev = node;
            node = next;
        }

        return prev;
    }
}
