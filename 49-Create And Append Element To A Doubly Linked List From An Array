class Solution {
    Node constructDLL(int arr[]) {
        // Dummy head simplifies list creation
        Node head = new Node(-1);

        // Tail pointer always points to the last node of the DLL
        Node tail = head;

        // Traverse the array and create nodes for the DLL
        for (int data : arr) {
            // Create a new node with current array value
            Node node = new Node(data);

            /*
             * Link the new node with the current tail
             *
             * tail <-> node
             */
            tail.next = node;
            node.prev = tail;

            // Move the tail pointer forward
            tail = tail.next;
        }

        /*
         * The first real node of the list is head.next
         * because head is a dummy node.
         */
        head = head.next;

        /*
         * Remove the backward link to the dummy node
         * so the real head's prev becomes null.
         */
        head.prev = null;

        // Return the head of the constructed DLL
        return head;
    }
}
